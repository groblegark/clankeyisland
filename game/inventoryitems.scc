/* Clanker City Chronicles -- inventory items. */

#include <scummVars6.s>
#include "common.sch"
#include "inventoryitems.sch"
#include "cityhall.sch"

room InventoryItems {

    object bolt {
        w = 40;
        h = 16;
        x = 0;
        name = "shiny bolt";
        states = {
            { 0, 0, "inventory/inv_bolt.bmp" }
        };
        state = 1;

        verb(int vrb,int objA,int objB) {
        case Preposition:
            if(vrb == Give)
                sntcPrepo[0] = "to";
            else
                sntcPrepo[0] = "with";
            return;
        case LookAt:
            egoSay("One genuine Clanker City bolt. Legal tender, light snack, structural member.");
            return;
        case Smell:
            egoSay("Mmm. Zinc-plated.");
            return;
        case Use:
            if(objB) {
                // route "Use me with/on X" to X's UsedWith -- the engine
                // dispatches to OUR script (objA), so a bare Use gag
                // here would swallow every two-object sentence
                if(getObjectVerbEntrypoint(objB, UsedWith)) {
                    startObject2(objB, UsedWith, [ UsedWith, objB, objA ]);
                    return;
                }
                egoSay("Those two things politely decline each other.");
                return;
            }
            egoSay("Saving it. Unless something jammed needs a shim more than I need a fortune.");
            return;
        }
    }

    object poster {
        w = 40;
        h = 16;
        x = 0;
        name = "official notice";
        states = {
            { 0, 0, "inventory/inv_poster.bmp" }
        };
        state = 1;

        verb(int vrb,int objA,int objB) {
        case Preposition:
            sntcPrepo[0] = "to";
            return;
        case LookAt:
            if(CityHallRoom::posterVoided) {
                egoSay("\"DYNAMO MAINTENANCE: NOTHING IS WRONG.\" Now with a VOID stamp.");
                waitForMessage();
                egoSay("Denied, then voided. The most official object I own.");
                return;
            }
            egoSay("\"DYNAMO MAINTENANCE: NOTHING IS WRONG. - Mayor Piston.\"");
            waitForMessage();
            egoSay("Nothing says 'something is wrong' like an official notice that nothing is wrong.");
            return;
        case Smell:
            egoSay("Fresh ink. Suspiciously fresh.");
            return;
        }
    }

    object token {
        w = 40;
        h = 16;
        x = 0;
        name = "drink token";
