                egoSay("Those two things politely decline each other.");
                return;
            }
            egoSay("Technician of record: O. CRANK. They cancelled the rewind and fired the bot who logged it. This paper is his name, cleared.");
            return;
        case Smell:
            egoSay("Municipal toner, then two centuries of bar grease. In that order.");
            return;
        }
    }

